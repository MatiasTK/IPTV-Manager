# IPTV Manager — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# JWT Secret (will be auto-generated if not set, but NOT suitable for multi-instance)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Health Checker
HEALTH_CHECK_INTERVAL_MS=900000
# 900000ms = 15 minutes
HEALTH_CHECK_TIMEOUT_MS=5000
# 5000ms = 5 seconds per stream

# Duplicate Detection
DUPLICATE_SIMILARITY_THRESHOLD=80
# 0-100, percentage similarity for name matching
